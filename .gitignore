# ==========================================================
# Python cache files
# ==========================================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================================
# Virtual environments
# ==========================================================
.venv/
venv/
env/
.biomec/

# ==========================================================
# IDE / editor files
# ==========================================================
.vscode/
.idea/
*.swp
*.swo

# ==========================================================
# macOS / Windows system files
# ==========================================================
.DS_Store
Thumbs.db
desktop.ini

# ==========================================================
# Generated analysis outputs
# ==========================================================
results/
Results/
output/
outputs/

# ==========================================================
# Local database files
# ==========================================================
database/
*.db
*.sqlite
*.sqlite3

# ==========================================================
# Large input video / RealSense files
# ==========================================================
*.bag
*.mp4
*.avi
*.mov
*.mkv
*.wmv

# ==========================================================
# Generated CSV / report / plot files
# Keep source code only in GitHub
# ==========================================================
*.csv
*.xlsx
*.xls
*.png
*.jpg
*.jpeg
*.html
*.txt

# ==========================================================
# Do not ignore documentation files
# ==========================================================
!README.md
!docs/**/*.md
!requirements.txt
!requirements_windows.txt
!requirements_macos.txt

# ==========================================================
# PyInstaller / build outputs
# ==========================================================
build/
dist/
*.spec

# ==========================================================
# Logs
# ==========================================================
*.log
logs/